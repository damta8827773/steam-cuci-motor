# Server Configuration
PORT=3001

# Database (SQLite path — relative to backend directory)
DATABASE_URL="file:./data/steam.db"

# JWT Secret — ganti dengan string random yang panjang dan unik
JWT_SECRET=your-very-long-and-secure-random-secret-here

# Owner Login Credentials
OWNER_EMAIL=your-owner-email@gmail.com
OWNER_PASSWORD=your-secure-password

# Email for receiving sensitive daily reports
REPORT_EMAIL=your-report-email@gmail.com

# Gmail SMTP Configuration
# Cara mendapatkan App Password:
# 1. Buka Google Account > Security
# 2. Aktifkan 2-Step Verification
# 3. Pergi ke App Passwords
# 4. Generate password baru untuk "Mail"
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
